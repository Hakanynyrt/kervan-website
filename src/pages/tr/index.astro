---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
const t = useTranslations('tr');
const alternates = [
  { lang: 'tr' as const, href: 'https://kervanheat.com/tr/' },
  { lang: 'en' as const, href: 'https://kervanheat.com/en/' },
];
---
<BaseLayout title={`${t('site.title')} · ${t('site.tagline')}`} alternates={alternates}>
<main class="container" style="padding-block: var(--space-7)">
<h1>{t('site.title')}</h1>
<p>{t('site.tagline')}</p>
</main>
</BaseLayout>
