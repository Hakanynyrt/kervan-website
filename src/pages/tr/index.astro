---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import TrustBar from '../../components/TrustBar.astro';
import LanguageHint from '../../components/LanguageHint.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('tr');
const alternates = [
  { lang: 'tr' as const, href: 'https://kervanheat.com/tr/' },
  { lang: 'en' as const, href: 'https://kervanheat.com/en/' },
];
---
<BaseLayout title={`${t('site.title')} · ${t('site.tagline')}`} alternates={alternates}>
<Header alternates={alternates} />
<TrustBar />
<main class="container" style="padding-block: var(--space-7); min-height: 60vh">
<h1>{t('site.title')}</h1>
<p>{t('site.tagline')}</p>
<p style="margin-top: var(--space-4); color: var(--text-muted)">Kervanheat TR — placeholder (FAZ 4'te split-hero ile zenginleşir).</p>
</main>
<Footer />
<LanguageHint alternates={alternates} />
</BaseLayout>
