---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import OrganizationSchema from '../../../components/seo/OrganizationSchema.astro';
import BreadcrumbSchema from '../../../components/seo/BreadcrumbSchema.astro';
import ArticleSchema from '../../../components/seo/ArticleSchema.astro';
import { useTranslations } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const cases = await getCollection('caseStudies');
  return cases.map((c) => ({ params: { slug: c.data.slug.tr }, props: { cs: c.data } }));
}
const { cs } = Astro.props;
const t = useTranslations('tr');
const canonical = `https://kervanheat.com/tr/referanslar/${cs.slug.tr}/`;
const alternates = [
  { lang: 'tr' as const, href: canonical },
  { lang: 'en' as const, href: `https://kervanheat.com/en/case-studies/${cs.slug.en}/` },
];
---
<BaseLayout title={`${cs.title.tr} — ${t('site.title')}`} description={cs.challenge.tr.slice(0,160)} canonical={canonical} alternates={alternates}>
<Fragment slot="head">
<OrganizationSchema />
<ArticleSchema title={cs.title.tr} description={cs.challenge.tr.slice(0,160)} image={cs.image} publishedAt={`${cs.year}-01-01`} url={canonical} />
<BreadcrumbSchema items={[
  { name: 'Ana Sayfa', url: '/tr/' },
  { name: t('nav.caseStudies'), url: '/tr/referanslar/' },
  { name: cs.title.tr, url: canonical },
]} />
</Fragment>
<Header alternates={alternates} />
<main class="container" style="padding-block: var(--space-7); max-width: 760px">
<p style="color: var(--text-muted); font-family: ui-monospace, monospace; font-size: var(--fs-sm); text-transform: uppercase; letter-spacing: .08em">{cs.year} · {cs.industry}</p>
<h1>{cs.title.tr}</h1>

<dl class="spec-list">
{Object.entries(cs.specs).map(([k, v]) => (
  <><dt>{k}</dt><dd>{v}</dd></>
))}
</dl>

<section style="margin-top: var(--space-6)"><h2>Zorluk</h2><p>{cs.challenge.tr}</p></section>
<section style="margin-top: var(--space-5)"><h2>Çözüm</h2><p>{cs.solution.tr}</p></section>
<section style="margin-top: var(--space-5)"><h2>Sonuç</h2><p>{cs.result.tr}</p></section>
</main>
<Footer />
</BaseLayout>

<style>
  .spec-list { display: grid; grid-template-columns: max-content 1fr; column-gap: var(--space-4); row-gap: var(--space-2); margin-top: var(--space-5); max-width: 600px; }
  .spec-list dt { color: var(--text-muted); font-family: ui-monospace, monospace; font-size: var(--fs-sm); text-transform: uppercase; letter-spacing: .08em; }
  .spec-list dd { color: var(--text-primary); margin: 0; }
  section h2 { font-size: var(--fs-xl); margin-bottom: var(--space-2); }
  section p { color: var(--text-secondary); }
</style>
