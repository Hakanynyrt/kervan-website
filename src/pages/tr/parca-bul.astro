---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import OrganizationSchema from '../../components/seo/OrganizationSchema.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import FindYourPartWrapper from '../../components/find-your-part/FindYourPartWrapper.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('tr');
const canonical = 'https://kervanheat.com/tr/parca-bul/';
const alternates = [
  { lang: 'tr' as const, href: canonical },
  { lang: 'en' as const, href: 'https://kervanheat.com/en/find-part/' },
];
---
<BaseLayout title={`${t('findPart.title')} — ${t('site.title')}`} description="OEM veya model numarası ile hidrolik kırıcı yedek parçası bul." canonical={canonical} alternates={alternates}>
<Fragment slot="head">
<OrganizationSchema />
<BreadcrumbSchema items={[{ name: 'Ana Sayfa', url: '/tr/' }, { name: t('findPart.title'), url: canonical }]} />
</Fragment>
<Header alternates={alternates} />
<main class="container" style="padding-block: var(--space-7)">
<h1>{t('findPart.title')}</h1>
<p style="color: var(--text-secondary); margin: var(--space-3) 0 var(--space-5); max-width: 60ch">
Marka, model, parça tipi veya OEM numarası ile filtreleyin. Sonuçları CSV olarak dışa aktarabilir, favorileyebilirsiniz.
</p>
<FindYourPartWrapper />
<p style="color: var(--text-muted); font-size: var(--fs-sm); margin-top: var(--space-5); font-style: italic">
Not: VEGA parça veritabanı (239 parça) henüz yüklenmedi. Aradığınız parçayı bulamazsanız <a href="/tr/iletisim/">bize sorun</a>.
</p>
</main>
<Footer />
</BaseLayout>
