---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import OrganizationSchema from '../../../components/seo/OrganizationSchema.astro';
import BreadcrumbSchema from '../../../components/seo/BreadcrumbSchema.astro';
import { useTranslations } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

const t = useTranslations('en');
const services = await getCollection('services');
const alternates = [
  { lang: 'tr' as const, href: 'https://kervanheat.com/tr/isil-islem/' },
  { lang: 'en' as const, href: 'https://kervanheat.com/en/heat-treatment/' },
];
---
<BaseLayout
  title={`${t('nav.services')} — ${t('site.title')}`}
  description="7 industrial heat-treatment services: carburizing, hardening, tempering, normalizing, stress relief, induction, flame hardening. Kartepe, Kocaeli."
  alternates={alternates}
>
<Fragment slot="head">
<OrganizationSchema />
<BreadcrumbSchema items={[
  { name: 'Home', url: '/en/' },
  { name: t('nav.services'), url: '/en/heat-treatment/' },
]} />
</Fragment>
<Header alternates={alternates} />
<main class="container" style="padding-block: var(--space-7)">
<h1>{t('nav.services')}</h1>
<p style="color: var(--text-secondary); max-width: 60ch; margin-block: var(--space-3) var(--space-6)">
Our Kartepe facility runs 7 industrial heat-treatment services — for our own parts and for third-party manufacturers. Pit furnace, controlled atmosphere, oil & polymer quench, induction line, and in-house HRC/HV metrology.
</p>
<ul class="svc-grid">
  {services.map((s) => (
    <li class="svc-card">
      <a href={`/en/heat-treatment/${s.data.slug.en}/`}>
        <h3>{s.data.name.en}</h3>
        <p>{s.data.shortDesc.en}</p>
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </li>
  ))}
</ul>
</main>
<Footer />
</BaseLayout>

<style>
  .svc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); list-style: none; padding: 0; margin: 0; }
  @media (max-width: 860px) { .svc-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .svc-grid { grid-template-columns: 1fr; } }
  .svc-card a { display: block; padding: var(--space-4); background: var(--bg-1); border: 1px solid var(--border); border-radius: var(--radius-lg); color: var(--text-primary); transition: border-color .2s, transform .2s; position: relative; }
  .svc-card a:hover { border-color: var(--accent-orange); transform: translateY(-2px); }
  .svc-card h3 { font-size: var(--fs-lg); margin-bottom: var(--space-2); }
  .svc-card p { color: var(--text-secondary); font-size: var(--fs-sm); margin: 0; }
  .svc-card .arrow { position: absolute; right: var(--space-4); bottom: var(--space-4); color: var(--accent-orange); font-size: var(--fs-xl); }
</style>
