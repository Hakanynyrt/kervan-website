---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import OrganizationSchema from '../../components/seo/OrganizationSchema.astro';
import LocalBusinessSchema from '../../components/seo/LocalBusinessSchema.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import RfqForm from '../../components/RfqForm.astro';

const canonical = 'https://kervanheat.com/en/contact/';
const alternates = [
  { lang: 'tr' as const, href: 'https://kervanheat.com/tr/iletisim/' },
  { lang: 'en' as const, href: canonical },
];
---
<BaseLayout title="Contact — Kervan Heat Treatment" description="Quote requests, address, phone, and map. Sadun Atığ Cad. No: 112/A Kartepe/Kocaeli, Turkey." canonical={canonical} alternates={alternates}>
<Fragment slot="head">
<OrganizationSchema />
<LocalBusinessSchema />
<BreadcrumbSchema items={[{ name: 'Home', url: '/en/' }, { name: 'Contact', url: canonical }]} />
</Fragment>
<Header alternates={alternates} />
<main class="container" style="padding-block: var(--space-7)">
<h1>Contact</h1>
<div class="contact-grid">
<div>
<h2 style="font-size: var(--fs-xl); margin-bottom: var(--space-3)">Request a Quote</h2>
<RfqForm />
</div>
<div>
<h2 style="font-size: var(--fs-xl); margin-bottom: var(--space-3)">Reach us</h2>
<dl class="contact-list">
<dt>Address</dt><dd>Sadun Atığ Cad. No: 112/A<br/>Kartepe / Kocaeli, Turkey</dd>
<dt>Phone</dt><dd><a href="tel:+905316693734">+90 531 669 37 34</a></dd>
<dt>Email</dt><dd><a href="mailto:info@kervanheat.com">info@kervanheat.com</a></dd>
<dt>WhatsApp</dt><dd><a href="https://wa.me/905316693734" target="_blank" rel="noopener">Send a message</a></dd>
<dt>Hours</dt><dd>Mon – Sat · 08:00 – 18:00 (GMT+3)</dd>
</dl>
</div>
</div>
</main>
<Footer />
</BaseLayout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-6); margin-top: var(--space-5); }
  @media (max-width: 780px) { .contact-grid { grid-template-columns: 1fr; } }
  .contact-list { display: grid; grid-template-columns: max-content 1fr; column-gap: var(--space-4); row-gap: var(--space-3); }
  .contact-list dt { color: var(--text-muted); font-family: ui-monospace, monospace; font-size: var(--fs-sm); text-transform: uppercase; letter-spacing: .08em; }
  .contact-list dd { color: var(--text-primary); margin: 0; }
  .contact-list a { color: var(--accent-orange); }
</style>
