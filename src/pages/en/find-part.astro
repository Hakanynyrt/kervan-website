---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import OrganizationSchema from '../../components/seo/OrganizationSchema.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import FindYourPartWrapper from '../../components/find-your-part/FindYourPartWrapper.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');
const canonical = 'https://kervanheat.com/en/find-part/';
const alternates = [
  { lang: 'tr' as const, href: 'https://kervanheat.com/tr/parca-bul/' },
  { lang: 'en' as const, href: canonical },
];
---
<BaseLayout title={`${t('findPart.title')} — ${t('site.title')}`} description="Find hydraulic breaker spare parts by OEM or model number." canonical={canonical} alternates={alternates}>
<Fragment slot="head">
<OrganizationSchema />
<BreadcrumbSchema items={[{ name: 'Home', url: '/en/' }, { name: t('findPart.title'), url: canonical }]} />
</Fragment>
<Header alternates={alternates} />
<main class="container" style="padding-block: var(--space-7)">
<h1>{t('findPart.title')}</h1>
<p style="color: var(--text-secondary); margin: var(--space-3) 0 var(--space-5); max-width: 60ch">
Filter by brand, model, part type, or OEM number. Export results as CSV, favorite items for later.
</p>
<FindYourPartWrapper />
<p style="color: var(--text-muted); font-size: var(--fs-sm); margin-top: var(--space-5); font-style: italic">
Note: VEGA parts database (239 entries) has not been imported yet. If you can't find what you're looking for, <a href="/en/contact/">ask us directly</a>.
</p>
</main>
<Footer />
</BaseLayout>
