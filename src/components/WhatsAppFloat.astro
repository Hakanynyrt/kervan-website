---
const phone = '905316693734';
---
<a
  class="wa-float"
  href={`https://wa.me/${phone}`}
  target="_blank"
  rel="noopener"
  aria-label="WhatsApp"
  data-wa-float
>
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="28" height="28">
    <path d="M17.5 14.4c-.3-.1-1.8-.9-2-1s-.5-.1-.7.1-.8 1-.9 1.2-.3.2-.6.1c-1.7-.9-2.9-1.6-4.1-3.6-.3-.5.3-.5.9-1.6.1-.2 0-.4 0-.5s-.7-1.7-1-2.3-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4s-1 1-1 2.5 1.1 2.9 1.2 3.1 2.1 3.2 5 4.4c.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.4s.2-1.3.2-1.4c-.1-.2-.3-.2-.5-.3zM12 2a10 10 0 0 0-8.6 15l-1.4 5 5.2-1.4A10 10 0 1 0 12 2z"/>
  </svg>
</a>

<script>
  document.querySelectorAll<HTMLAnchorElement>('[data-wa-float]').forEach((el) => {
    el.addEventListener('click', () => {
      (window as any).dataLayer = (window as any).dataLayer || [];
      (window as any).dataLayer.push({ event: 'whatsapp_click', page: location.pathname });
    });
  });
</script>

<style>
  .wa-float {
    position: fixed;
    right: calc(1rem + var(--safe-right));
    bottom: calc(1rem + var(--safe-bottom));
    z-index: 30;
    width: 56px; height: 56px;
    border-radius: 50%;
    display: grid; place-items: center;
    background: #25d366; color: #fff;
    box-shadow: 0 8px 24px rgba(37, 211, 102, 0.35);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .wa-float:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(37, 211, 102, 0.45);
  }
  @media (max-width: 560px) {
    .wa-float { width: 52px; height: 52px; }
  }
</style>
