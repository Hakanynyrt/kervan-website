---
import {
  getLangFromUrl,
  useTranslations,
  getLocalizedPath,
} from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---
<footer class="foot" role="contentinfo">
  <div class="foot__main container">
    <div class="foot__brand">
      <div class="foot__brand-row">
        <span class="brand-mark" aria-hidden="true">K</span>
        <span class="brand-text">Kervan<b>Heat</b></span>
      </div>
      <p class="foot__tag">{t('site.tagline')}</p>
      <p class="foot__addr">{t('footer.address')}</p>
    </div>

    <div class="foot__col">
      <h4>{t('nav.services')}</h4>
      <ul>
        <li><a href={getLocalizedPath(lang, 'services') + '/'}>{t('cta.seeAll')}</a></li>
      </ul>
    </div>

    <div class="foot__col">
      <h4>{t('nav.parts')}</h4>
      <ul>
        <li><a href={getLocalizedPath(lang, 'parts') + '/'}>{t('cta.seeAll')}</a></li>
        <li><a href={getLocalizedPath(lang, 'findPart') + '/'}>{t('nav.findPart')}</a></li>
      </ul>
    </div>

    <div class="foot__col">
      <h4>{t('nav.about')}</h4>
      <ul>
        <li><a href={getLocalizedPath(lang, 'about') + '/'}>{t('nav.about')}</a></li>
        <li><a href={getLocalizedPath(lang, 'contact') + '/'}>{t('nav.contact')}</a></li>
        <li><a href={getLocalizedPath(lang, 'certifications') + '/'}>{t('nav.certifications')}</a></li>
        <li><a href={getLocalizedPath(lang, 'privacy') + '/'}>
          {lang === 'tr' ? 'KVKK' : 'Privacy'}
        </a></li>
        <li><a href={getLocalizedPath(lang, 'cookies') + '/'}>
          {lang === 'tr' ? 'Çerez Politikası' : 'Cookie Policy'}
        </a></li>
        <li><button type="button" class="foot__cookiebtn" onclick="window.openCookiePrefs && window.openCookiePrefs()">{t('footer.cookiePrefs')}</button></li>
      </ul>
    </div>
  </div>
  <div class="foot__bottom container">
    <span>© {year} Kervan Isıl İşlem Ltd. Şti. · {t('footer.rights')}</span>
    <span>{t('footer.vat')}: [VKN]</span>
  </div>
</footer>

<style>
  .foot {
    background: var(--bg-1);
    border-top: 1px solid var(--border);
    padding-top: var(--space-7);
    padding-bottom: calc(var(--space-4) + var(--safe-bottom));
    color: var(--text-secondary);
  }
  .foot__main {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: var(--space-5);
    padding-bottom: var(--space-5);
  }
  .foot__brand-row {
    display: inline-flex; align-items: center; gap: 0.6rem;
    color: var(--text-primary); font-weight: 700;
  }
  .brand-mark {
    width: 30px; height: 30px; border-radius: 6px;
    display: grid; place-items: center;
    background: linear-gradient(145deg, var(--accent-orange), #b85510);
    color: #111; font-weight: 800; font-size: 14px;
  }
  .brand-text b { color: var(--accent-orange); }
  .foot__tag { margin: 0.75rem 0 0.25rem; color: var(--text-secondary); font-size: var(--fs-sm); }
  .foot__addr { margin: 0; color: var(--text-muted); font-size: var(--fs-sm); }
  .foot__col h4 {
    font-size: var(--fs-sm);
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .foot__col ul {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .foot__col a, .foot__cookiebtn {
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    text-align: left;
  }
  .foot__col a:hover, .foot__cookiebtn:hover { color: var(--accent-orange); }
  .foot__bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
    font-size: var(--fs-xs);
    color: var(--text-muted);
  }
  @media (max-width: 720px) {
    .foot__main { grid-template-columns: 1fr; }
  }
</style>
