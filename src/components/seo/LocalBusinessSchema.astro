---
const site = Astro.site?.origin ?? 'https://kervanheat.com';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${site}/#localbusiness`,
  name: 'Kervan Isıl İşlem',
  image: `${site}/hero.jpg`,
  url: site,
  telephone: '+905316693734',
  email: 'info@kervanheat.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Sadun Atığ Cad. No: 112/A',
    addressLocality: 'Kartepe',
    addressRegion: 'Kocaeli',
    postalCode: '41250',
    addressCountry: 'TR',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 40.7559, longitude: 30.0711 },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '08:00',
      closes: '18:00',
    },
  ],
  priceRange: '$$',
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
