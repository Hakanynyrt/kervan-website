---
export interface Props {
  title: string;
  description: string;
  image: string;
  publishedAt: string;
  url: string;
}
const { title, description, image, publishedAt, url } = Astro.props;
const site = Astro.site?.origin ?? 'https://kervanheat.com';
const fullImage = image.startsWith('http') ? image : `${site}${image}`;
const fullUrl = url.startsWith('http') ? url : `${site}${url}`;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: fullImage,
  datePublished: publishedAt,
  url: fullUrl,
  author: { '@id': `${site}/#org` },
  publisher: { '@id': `${site}/#org` },
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
