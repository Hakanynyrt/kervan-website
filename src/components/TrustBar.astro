---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items = [
  { key: 'trust.iso', icon: 'iso' },
  { key: 'trust.experience', icon: 'clock' },
  { key: 'trust.export', icon: 'globe' },
  { key: 'trust.capacity', icon: 'factory' },
] as const;
---
<section class="trustbar" aria-label="Trust indicators">
  <div class="container trustbar__grid">
    {items.map((it) => (
      <div class="trust-item">
        <span class="trust-item__icon" aria-hidden="true">
          {it.icon === 'iso' && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2 4 5v7c0 5 3.5 9 8 10 4.5-1 8-5 8-10V5l-8-3z"/><path d="M9 12l2 2 4-4"/></svg>
          )}
          {it.icon === 'clock' && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          )}
          {it.icon === 'globe' && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M2 12h20M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>
          )}
          {it.icon === 'factory' && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 20h18V9l-6 3V9l-6 3V4H3z"/><path d="M7 20v-4M11 20v-4M15 20v-4"/></svg>
          )}
        </span>
        <span class="trust-item__label">{t(it.key as any)}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .trustbar {
    background: var(--bg-2);
    border-block: 1px solid var(--border);
    padding-block: var(--space-4);
  }
  .trustbar__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  .trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    font-weight: 500;
  }
  .trust-item__icon {
    width: 38px; height: 38px; border-radius: 8px;
    display: grid; place-items: center;
    background: linear-gradient(145deg, rgba(255,122,0,.15), rgba(255,122,0,.03));
    border: 1px solid rgba(255,122,0,.3);
    color: var(--accent-orange);
  }
  @media (max-width: 780px) {
    .trustbar__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .trustbar__grid { grid-template-columns: 1fr; }
  }
</style>
