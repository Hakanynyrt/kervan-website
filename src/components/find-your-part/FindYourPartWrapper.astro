---
import FindYourPart from './FindYourPart.tsx';
import type { VegaPart } from './FindYourPart.tsx';
import { getLangFromUrl } from '../../i18n/utils';
import vegaParts from '../../data/vega-parts.json';

const lang = getLangFromUrl(Astro.url);
const data = vegaParts as VegaPart[];
---
<div class="fyp-shell">
<FindYourPart client:visible data={data} lang={lang} />
<noscript>
<p style="color: var(--text-muted); font-style: italic; padding: 1rem 0">
{lang === 'tr' ? 'Parça bulucu için JavaScript gerekir.' : 'Part finder requires JavaScript.'}
</p>
</noscript>
</div>

<style>
  .fyp-shell { min-height: 400px; }
</style>
